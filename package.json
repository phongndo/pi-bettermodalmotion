{
  "name": "pi-modal-motion",
  "version": "0.1.0",
  "private": false,
  "description": "Vim-inspired modal editing and motion experiments for pi's input editor.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "modal-editor",
    "vim",
    "motions"
  ],
  "files": [
    "src",
    "docs",
    "README.md"
  ],
  "scripts": {
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "ci": "npm run check && npm run pack:check",
    "dev:pi": "pi -e .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --max-warnings 0 src test vitest.config.ts",
    "lint:fix": "npm run lint -- --fix",
    "pack:check": "npm pack --dry-run --ignore-scripts",
    "prepack": "npm run check",
    "release:verify": "npm run check && npm run pack:check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.70.2 <0.71.0",
    "@mariozechner/pi-tui": ">=0.70.2 <0.71.0"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "@mariozechner/pi-tui": "^0.70.2",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phongndo/pi-modal-motion.git"
  }
}
